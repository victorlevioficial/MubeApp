default_platform(:ios)

require "shellwords"

platform :ios do
  desc "Build the iOS IPA for App Store distribution"
  lane :build_ipa do |options|
    repo_root = File.expand_path("../..", __dir__)
    export_method = options[:export_method] || "app-store"
    maps_api_key = ENV["GOOGLE_MAPS_API_KEY"].to_s.strip
    vision_api_key = ENV["GOOGLE_VISION_API_KEY"].to_s.strip

    UI.user_error!("Set GOOGLE_MAPS_API_KEY before running iOS release lanes.") if maps_api_key.empty?

    build_command = [
      "flutter",
      "build",
      "ipa",
      "--release",
      "--export-method",
      export_method.to_s,
      "--dart-define=GOOGLE_MAPS_API_KEY=#{maps_api_key}",
    ]
    build_command << "--dart-define=GOOGLE_VISION_API_KEY=#{vision_api_key}" unless vision_api_key.empty?

    sh("cd #{repo_root.shellescape} && #{build_command.map(&:shellescape).join(' ')}")
  end

  desc "Upload an existing IPA to TestFlight using App Store Connect API key"
  lane :upload_testflight do |options|
    repo_root = File.expand_path("../..", __dir__)
    ipa_path = options[:ipa] || File.join(repo_root, "build", "ios", "ipa", "mube.ipa")
    UI.user_error!("IPA not found at #{ipa_path}") unless File.exist?(ipa_path)

    pilot(
      api_key: load_asc_api_key,
      ipa: ipa_path,
      skip_submission: options.key?(:skip_submission) ? options[:skip_submission] : true,
      skip_waiting_for_build_processing: options.key?(:skip_waiting_for_build_processing) ? options[:skip_waiting_for_build_processing] : true
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do |options|
    build_ipa(export_method: options[:export_method] || "app-store")
    upload_testflight(
      ipa: options[:ipa],
      skip_submission: options[:skip_submission],
      skip_waiting_for_build_processing: options[:skip_waiting_for_build_processing]
    )
  end

  desc "Upload local dSYMs to Firebase Crashlytics"
  lane :upload_dsyms do |options|
    repo_root = File.expand_path("../..", __dir__)
    archive_path = options[:archive] || File.join(repo_root, "build", "ios", "archive", "Runner.xcarchive")
    dsym_path = options[:dsym] || File.join(archive_path, "dSYMs")
    gsp_path = options[:gsp] || File.join(repo_root, "ios", "Runner", "GoogleService-Info.plist")
    upload_symbols_bin = File.join(repo_root, "ios", "Pods", "FirebaseCrashlytics", "upload-symbols")

    UI.user_error!("Crashlytics upload-symbols not found at #{upload_symbols_bin}") unless File.exist?(upload_symbols_bin)
    UI.user_error!("GoogleService-Info.plist not found at #{gsp_path}") unless File.exist?(gsp_path)
    UI.user_error!("dSYMs not found at #{dsym_path}") unless File.exist?(dsym_path)

    sh(
      "#{upload_symbols_bin.shellescape} " \
      "-gsp #{gsp_path.shellescape} " \
      "-p ios " \
      "#{dsym_path.shellescape}"
    )
  end

  private_lane :load_asc_api_key do
    key_id = ENV["ASC_KEY_ID"]
    issuer_id = ENV["ASC_ISSUER_ID"]
    key_filepath = ENV["ASC_KEY_FILEPATH"]

    UI.user_error!("Set ASC_KEY_ID before running Fastlane.") if key_id.to_s.empty?
    UI.user_error!("Set ASC_ISSUER_ID before running Fastlane.") if issuer_id.to_s.empty?
    UI.user_error!("Set ASC_KEY_FILEPATH before running Fastlane.") if key_filepath.to_s.empty?
    UI.user_error!("App Store Connect key file not found: #{key_filepath}") unless File.exist?(key_filepath)

    app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_filepath: key_filepath,
      in_house: false
    )
  end
end
